<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@android:color/white"
    android:layout_marginBottom="8dp"
    android:elevation="1dp">

    <!-- Thông tin nhân viên (chỉ hiện với Admin/HR/Manager) -->
    <TextView
        android:id="@+id/tv_ma_nv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mã NV: NV001"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#333"
        android:layout_marginBottom="4dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tv_ho_ten"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Họ tên: Nguyễn Văn A"
        android:textSize="14sp"
        android:textColor="#666"
        android:layout_marginBottom="8dp"
        android:visibility="gone" />

    <!-- Thông tin chấm công -->
    <TextView
        android:id="@+id/tv_ngay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ngày: 2024-01-15"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#333"
        android:layout_marginBottom="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_gio_vao"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Giờ vào: 08:00"
            android:textSize="14sp"
            android:textColor="#666" />

        <TextView
            android:id="@+id/tv_gio_ra"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Giờ ra: 17:00"
            android:textSize="14sp"
            android:textColor="#666" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/tv_so_gio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Số giờ: 8.0"
            android:textSize="14sp"
            android:textColor="#666" />

        <TextView
            android:id="@+id/tv_trang_thai"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Trạng thái: Có mặt"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="end" />

    </LinearLayout>

    <!-- Buttons sửa/xóa (chỉ hiện với Admin/HR/Manager) -->
    <LinearLayout
        android:id="@+id/layout_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginTop="8dp"
        android:visibility="gone">

        <Button
            android:id="@+id/btn_xoa"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="XÓA"
            android:textSize="12sp"
            android:textColor="@android:color/holo_red_dark"
            android:background="@drawable/btn_secondary"
            android:layout_marginEnd="8dp"
            android:minWidth="60dp" />

        <Button
            android:id="@+id/btn_sua"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="SỬA"
            android:textSize="12sp"
            android:textColor="@android:color/white"
            android:background="@drawable/btn_primary"
            android:minWidth="60dp" />

    </LinearLayout>

</LinearLayout>